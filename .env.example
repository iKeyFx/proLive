# ──────────────────────────────────────────────────────────────────────────
# ProLive environment — copy to .env.local and fill in. NEVER commit .env.local.
# ──────────────────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase ANON key — safe to expose to the browser. RLS is what protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase SERVICE-ROLE key — SERVER ONLY. Bypasses RLS. Never prefix with
# NEXT_PUBLIC_ and never import into a client component. Used only by the seed
# script and trusted server actions that must operate across the audit ledger.
SUPABASE_SERVICE_ROLE_KEY=

# Price simulator WebSocket the browser connects to (must be allowed by CSP).
NEXT_PUBLIC_FEED_WS_URL=ws://localhost:4001

# Port the in-house simulator listens on (server side).
FEED_WS_PORT=4001
